rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções auxiliares ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'super_admin';
    }

    function isSupport() {
      return isAuthenticated() && getUserData().role == 'support';
    }

    function isActive() {
      return isAuthenticated() && getUserData().status == 'active';
    }

    function isSameEmpresa(empresaId) {
      return isAuthenticated() && getUserData().empresaId == empresaId;
    }

    // ── Usuários (/usuarios/{uid}) ────────────────────────────────────────────

    match /usuarios/{uid} {
      // Leitura: próprio perfil, qualquer autenticado (para checar matrícula no cadastro),
      //          admin da mesma empresa ou super_admin (global)
      allow read: if isOwner(uid)
        || isAuthenticated()
        || (isActive() && isAdmin() && isSameEmpresa(resource.data.empresaId))
        || (isActive() && isSuperAdmin());

      // Criação: apenas durante o registro (usuário autenticado criando o próprio doc)
      allow create: if isOwner(uid);

      // Atualização: próprio perfil, admin da empresa ou super_admin
      allow update: if isOwner(uid)
        || (isActive() && isAdmin() && isSameEmpresa(resource.data.empresaId))
        || (isActive() && isSuperAdmin());

      // Exclusão: admin da empresa ou super_admin
      allow delete: if (isActive() && isAdmin() && isSameEmpresa(resource.data.empresaId))
        || (isActive() && isSuperAdmin());
    }

    // ── Empresas (/empresas/{empresaId}) ─────────────────────────────────────

    match /empresas/{empresaId} {
      // Leitura: público (necessário para busca por código no cadastro)
      allow read: if true;

      // Criação: qualquer usuário autenticado (somente no registro do primeiro admin)
      allow create: if isAuthenticated();

      // Atualização/exclusão: admin da empresa ou super_admin
      allow update, delete: if (isActive() && isAdmin() && getUserData().empresaId == empresaId)
        || (isActive() && isSuperAdmin());
    }

    // ── Inventário (/inventario/{docId}) ─────────────────────────────────────

    match /inventario/{docId} {
      // Leitura:
      //   - qualquer usuário autenticado lendo seus próprios registros (independente de status)
      //   - admin ativo da mesma empresa (query por empresaId)
      //   - super_admin (sem filtro)
      allow read: if (isAuthenticated() && resource.data.usuarioId == request.auth.uid)
        || (isActive() && isSameEmpresa(resource.data.empresaId))
        || (isActive() && isSuperAdmin());

      // Criação: qualquer usuário autenticado criando o próprio registro
      // (não exige isActive para permitir uso mesmo com conta pendente de aprovação)
      allow create: if isAuthenticated()
        && request.resource.data.usuarioId == request.auth.uid;

      // Atualização/exclusão: admin da empresa, super_admin ou curadoria de dataset pelo super_admin
      allow update, delete: if (isActive() && isAdmin() && isSameEmpresa(resource.data.empresaId))
        || (isActive() && isSuperAdmin());
    }

    // ── Chamados (/chamados/{docId}) ──────────────────────────────────────────

    match /chamados/{docId} {
      // Leitura: admin da empresa, super_admin ou support
      allow read: if (isAuthenticated() && resource.data.adminId == request.auth.uid)
        || (isActive() && isAdmin() && isSameEmpresa(resource.data.empresaId))
        || (isActive() && isSuperAdmin())
        || (isActive() && isSupport());

      // Criação: admin ativo
      allow create: if isActive() && isAdmin();

      // Atualização de status/resposta: super_admin ou support
      allow update: if (isActive() && isSuperAdmin())
        || (isActive() && isSupport())
        || (isActive() && isAdmin() && isSameEmpresa(resource.data.empresaId));

      allow delete: if isActive() && isSuperAdmin();
    }

    // ── Notificações (/notificacoes/{docId}) ──────────────────────────────────

    match /notificacoes/{docId} {
      // Leitura e atualização: apenas o destinatário da notificação
      allow read, update: if isAuthenticated()
        && resource.data.paraUid == request.auth.uid;

      // Criação: qualquer usuário autenticado pode criar notificações para outros
      // (triggers do app — authService, supportService)
      allow create: if isAuthenticated();

      // Exclusão: apenas o destinatário
      allow delete: if isAuthenticated()
        && resource.data.paraUid == request.auth.uid;
    }

    // ── Auditoria de login (/login_audit/{docId}) ─────────────────────────────

    match /login_audit/{docId} {
      // Apenas o próprio usuário autenticado pode registrar seu login
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      // Leitura restrita a admins e super_admins ativos
      allow read: if isActive() && (isAdmin() || isSuperAdmin());
      allow update, delete: if false;
    }

    // ── Convites de suporte (/convites_suporte/{email}) ───────────────────────

    match /convites_suporte/{email} {
      // Super admin gerencia convites
      allow create, delete: if isActive() && isSuperAdmin();
      allow read: if (isActive() && isSuperAdmin())
        || (isAuthenticated() && request.auth.token.email == email);

      // Técnico consome o próprio convite durante o cadastro
      allow update: if isAuthenticated()
        && request.auth.token.email == email
        && resource.data.usado == false;
    }
  }
}
