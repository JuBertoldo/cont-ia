YOLO_MODEL=yolo11m.pt
YOLO_CONF=0.25
YOLO_TIMEOUT_S=60
API_ENV=development
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
RATE_LIMIT=30/minute

# Sentry — deixe vazio para desativar o monitoramento
SENTRY_DSN=

# Ensemble — Roboflow RF-DETR (deixe vazio para usar só YOLO)
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=julianas-workspace-fcaqd
ROBOFLOW_WORKFLOW_ID=smart-bottle-counting-pipeline-1776046255903
ENSEMBLE_IOU_THRESHOLD=0.5

# E-mail (SMTP) — notificações de ticket
# Gmail: crie uma "Senha de app" em myaccount.google.com/security → Segurança → Senhas de app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app
EMAIL_FROM_NAME=Cont.IA Suporte
