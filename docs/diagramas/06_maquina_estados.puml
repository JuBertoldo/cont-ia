@startuml 06_maquina_estados
title Cont.IA — Máquina de Estados: Ciclo de Vida dos Usuários

skinparam backgroundColor #FFFFFF
skinparam stateBackgroundColor #F0FFF4
skinparam stateBorderColor #00E676
skinparam stateFontColor #1A1A1A
skinparam arrowColor #555555
skinparam titleFontColor #1A1A1A
skinparam titleFontSize 16
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #F59E0B
skinparam noteFontColor #555555

' ════════════════════════════════════════════════════
' FLUXO A — Cadastro padrão (Operador / Admin)
' ════════════════════════════════════════════════════

[*] --> EscolhaTipo : Abre tela de cadastro

state EscolhaTipo {
    [*] --> SemEmpresa : "Não tenho empresa"
    [*] --> ComEmpresa : "Já tenho empresa"
}

' --- Caminho A: cria empresa → vira Admin ---

SemEmpresa --> CriandoEmpresa : Preenche nome da empresa\n+ dados pessoais

state CriandoEmpresa {
    [*] --> CriaContaAuth
    CriaContaAuth --> CriaEmpresaFirestore
    CriaEmpresaFirestore --> [*]
}

CriandoEmpresa --> AtivoAdmin : role = admin\nstatus = active\n(sem aprovação)

note right of AtivoAdmin
  Primeiro usuário de uma empresa
  torna-se Admin automaticamente
  com status = active.
end note

' --- Caminho B: usa código → vira Operador pendente ---

ComEmpresa --> ValidandoCodigo : Digita código\nda empresa (debounce 600ms)

state ValidandoCodigo {
    [*] --> CodigoOK : Encontrado
    [*] --> CodigoErro : Não encontrado
    CodigoErro --> ValidandoCodigo : Corrige o código
}

ValidandoCodigo --> Pendente : Cadastro enviado\nrole = user, status = pending

state Pendente {
    [*] --> AguardandoAdmin
    AguardandoAdmin : Tela "Aguardando Aprovação"
}

note right of Pendente
  Usuário pode escanear e ver
  próprio histórico mesmo pendente,
  mas não acessa dados de outros.
end note

Pendente --> Ativo : Admin aprova
Pendente --> Recusado : Admin recusa

' --- Estados principais ---

state Ativo {
    [*] --> Operando
    Operando --> RealizandoContagem : Inicia scanner
    RealizandoContagem --> Operando : Confirma ou cancela
}

note right of Ativo
  Acesso conforme role:
  - user  → scanner + histórico próprio
  - admin → + gerenciar empresa + chamados
end note

state AtivoAdmin {
    [*] --> OperandoAdmin
    OperandoAdmin --> GerenciandoUsuarios : Acessa painel admin
    GerenciandoUsuarios --> OperandoAdmin : Volta ao app
}

state Recusado {
    [*] --> AcessoBloqueado
    AcessoBloqueado : Login negado automaticamente
}

Ativo --> Recusado : Admin revoga acesso
Recusado --> Ativo : Admin reativa
Ativo --> [*] : Usuário excluído

' ════════════════════════════════════════════════════
' FLUXO B — Cadastro por convite (Suporte Técnico)
' ════════════════════════════════════════════════════

state ConvitePendente {
    [*] --> AguardandoTecnico
    AguardandoTecnico : /convites_suporte/{email}\nusado = false
}

state ValidandoConvite {
    [*] --> ChecandoFirestore
    ChecandoFirestore --> ConviteOK : Email tem convite nao usado
    ChecandoFirestore --> ConviteNegado : Email sem convite ou ja usado
    ConviteNegado --> [*] : Conta Auth deletada automaticamente
}

state AtivoSupport {
    [*] --> GerenciandoChamados
    GerenciandoChamados --> RespondendoChamado : Abre ticket
    RespondendoChamado --> GerenciandoChamados : Salva resposta
}

[*] --> ConvitePendente : Super Admin cria convite\nno painel do sistema

ConvitePendente --> ValidandoConvite : Tecnico: duplo toque no logo\n+ preenche email e senha

ValidandoConvite --> AtivoSupport : Convite consumido\nrole = support, status = active

note right of AtivoSupport
  Acesso restrito apenas a:
  chamados de todas as empresas.
  Sem scanner, sem historico,
  sem gestao de usuarios.
end note

AtivoSupport --> [*] : Conta excluida pelo Super Admin

@enduml
