@startuml 12_cadastro_usuario_admin
title Cont.IA — Sequência: Cadastro de Operador e Administrador

skinparam backgroundColor #FFFFFF
skinparam participantBackgroundColor #F0FFF4
skinparam participantBorderColor #00E676
skinparam participantFontColor #1A1A1A
skinparam sequenceArrowColor #555555
skinparam sequenceLifeLineBorderColor #00E676
skinparam titleFontColor #1A1A1A
skinparam titleFontSize 16
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #F59E0B
skinparam noteFontColor #555555

actor "Usuario" as USR
participant "RegisterScreen" as REG
participant "Firestore /empresas" as FS_EMP
participant "Firebase Auth" as FB_AUTH
participant "Firestore /usuarios" as FS_USR
participant "AdminUsersScreen" as ADMIN_APP
actor "Administrador" as ADM

note over USR, FS_USR
  Dois caminhos: "Nao tenho empresa" (vira Admin) ou "Ja tenho empresa" (vira Operador pendente)
end note

' ════════════════════════════════════════════
' FLUXO A — Novo Administrador (cria empresa)
' ════════════════════════════════════════════

group Fluxo A: "Nao tenho empresa" - vira Administrador

USR -> REG : Seleciona "Nao tenho empresa"\nPreenche nome, email, senha, matricula, nome da empresa
USR -> REG : Clica "Cadastrar"

REG -> FB_AUTH : createUserWithEmailAndPassword(email, senha)
FB_AUTH --> REG : userCredential (uid)

REG -> FB_AUTH : updateProfile(displayName: nome)
FB_AUTH --> REG : ok

REG -> FS_EMP : addDoc(/empresas, { nome, codigo, adminUid })
FS_EMP --> REG : empresaId

note right of FS_EMP
  Codigo gerado automaticamente
  ex: EMP-4K2X
  Usado por outros usuarios
  para entrar nesta empresa.
end note

REG -> FS_USR : setDoc(/usuarios/{uid}, { role: admin, status: active, empresaId })
FS_USR --> REG : ok

REG -> USR : Alert "Empresa criada!" - Acesso liberado direto

note right of REG
  Admin com status = active.
  Nao precisa de aprovacao.
end note

end

' ════════════════════════════════════════════
' FLUXO B — Novo Operador (entra em empresa)
' ════════════════════════════════════════════

group Fluxo B: "Ja tenho empresa" - Operador aguardando aprovacao

USR -> REG : Seleciona "Ja tenho empresa"\nDigita codigo da empresa (validacao em tempo real)

REG -> FS_EMP : getEmpresaByCodigo(codigo)
FS_EMP --> REG : { id, nome } ou null

note right of REG
  Validacao com debounce 600ms.
  Codigo invalido bloqueia o cadastro.
end note

USR -> REG : Preenche nome, email, senha, matricula\nClica "Cadastrar"

REG -> FB_AUTH : createUserWithEmailAndPassword(email, senha)
FB_AUTH --> REG : userCredential (uid)

REG -> FB_AUTH : updateProfile(displayName: nome)
FB_AUTH --> REG : ok

REG -> FS_USR : checkMatriculaExists(matricula, empresaId)

alt Matricula ja cadastrada nesta empresa
    FS_USR --> REG : true
    REG -> FB_AUTH : deleteUser() - rollback automatico
    REG -> USR : Alert "Matricula ja cadastrada nesta empresa"
else Matricula disponivel
    FS_USR --> REG : false
    REG -> FS_USR : setDoc(/usuarios/{uid}, { role: user, status: pending, empresaId })
    FS_USR --> REG : ok
    REG -> USR : Alert "Aguardando aprovacao" - Tela PendingApproval
end

end

' ════════════════════════════════════════════
' FLUXO C — Admin aprova ou recusa
' ════════════════════════════════════════════

group Fluxo C: Administrador aprova ou recusa o cadastro

ADM -> ADMIN_APP : Abre "Gerenciar Usuarios"
ADMIN_APP -> FS_USR : onSnapshot(empresaId, status: pending) - tempo real
FS_USR --> ADMIN_APP : Lista de pendentes

ADM -> ADMIN_APP : Visualiza perfil: nome, email, matricula

alt Admin aprova
    ADM -> ADMIN_APP : Clica "Aprovar"
    ADMIN_APP -> FS_USR : updateDoc({ status: active })
    FS_USR --> ADMIN_APP : ok
    note right of ADMIN_APP
      Usuario faz login novamente
      e acessa o app com role = user.
    end note
else Admin recusa
    ADM -> ADMIN_APP : Clica "Recusar"
    ADMIN_APP -> FS_USR : updateDoc({ status: rejected })
    FS_USR --> ADMIN_APP : ok
    note right of ADMIN_APP
      Usuario recebe "Acesso negado"
      na proxima tentativa de login.
    end note
end

end

note over REG, FB_AUTH
  Rollback automatico: se qualquer etapa apos a criacao no Firebase Auth falhar,
  a conta e deletada automaticamente para nao deixar usuario sem perfil no Firestore.
end note

@enduml
