@startuml 05_implantacao
!pragma layout smetana
title Cont.IA — Diagrama de Implantação

skinparam backgroundColor #FFFFFF
skinparam nodeBackgroundColor #F0FFF4
skinparam nodeBorderColor #00E676
skinparam nodeFontColor #1A1A1A
skinparam componentBackgroundColor #FFFFFF
skinparam componentBorderColor #333333
skinparam componentFontColor #333333
skinparam arrowColor #00E676
skinparam titleFontColor #1A1A1A
skinparam titleFontSize 16
skinparam artifactBackgroundColor #1B5E3B
skinparam artifactBorderColor #00E676
skinparam artifactFontColor #F1F5F9
skinparam databaseBackgroundColor #FFF8E1
skinparam databaseBorderColor #F59E0B
skinparam databaseFontColor #E65100

node "Dispositivo Móvel\n(iOS / Android)" as DEVICE {
    component "Cont.IA App\n(React Native)" as APP
    component "Câmera" as CAM
    component "GPS" as GPS
    CAM --> APP
    GPS --> APP
}

node "Servidor de Produção\n(Cloud / VPS)" as SERVER {
    component "Backend\n(FastAPI + Uvicorn)" as API
    component "YOLO11\n(yolo11m.pt)" as YOLO
    component "Python 3.11" as PY
    API --> YOLO
    PY --> API
}

node "Google Firebase\n(Google Cloud)" as FIREBASE {
    database "Cloud Firestore\n(Banco de dados)" as FS
    database "Cloud Storage\n(Imagens)" as STORAGE
    component "Firebase Auth\n(JWT)" as AUTH
}

node "Roboflow\n(API Cloud)" as ROBOFLOW {
    component "RF-DETR Workflow\n(Inference API)" as RFDETR
}

APP --> API : HTTPS\nPOST /v1/detect\n(Base64 + JWT)
API --> RFDETR : HTTPS\nInference SDK
API --> FS : Firebase Admin SDK
APP --> FS : Firebase SDK\n(Firestore)
APP --> STORAGE : Firebase SDK\n(Upload imagem)
APP --> AUTH : Firebase SDK\n(Autenticação)
AUTH --> API : Validação JWT

note bottom of DEVICE
  Usuário acessa o app
  pelo smartphone pessoal.
  Sem custo de hardware.
end note

note bottom of FIREBASE
  Plano Spark (gratuito)
  até 50 empresas ativas.
  Escalável sob demanda.
end note

@enduml
