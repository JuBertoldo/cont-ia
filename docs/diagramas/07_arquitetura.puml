@startuml 07_arquitetura
!pragma layout smetana
title Cont.IA — Arquitetura Geral do Sistema

skinparam backgroundColor #FFFFFF
skinparam nodeBackgroundColor #F0FFF4
skinparam nodeBorderColor #00E676
skinparam nodeFontColor #1A1A1A
skinparam componentBackgroundColor #FFFFFF
skinparam componentBorderColor #333333
skinparam componentFontColor #333333
skinparam arrowColor #00E676
skinparam titleFontColor #1A1A1A
skinparam titleFontSize 16
skinparam databaseBackgroundColor #FFF8E1
skinparam databaseBorderColor #F59E0B
skinparam databaseFontColor #E65100

left to right direction

' ── App Mobile ───────────────────────────────────────────────────────────────

node "Dispositivo Movel\n(iOS / Android)" as MOBILE {
    component "App Cont.IA\n(React Native 0.84)" as APP
    component "Camera / Galeria" as CAM
    component "GPS" as GPS
    CAM --> APP : captura imagem
    GPS --> APP : coordenadas
}

' ── Infraestrutura do Backend ────────────────────────────────────────────────

node "Servidor Local\n(Mac — Docker)" as SERVER {

    node "Docker Container\n(python:3.11-slim)" as DOCKER {
        component "API REST\nFastAPI + Uvicorn" as API
        component "YOLO11m\n(Ultralytics — CPU)" as YOLO
        component "NMS Ensemble\n(merge por classe)" as NMS

        API --> YOLO : detect(image)
        API --> NMS : merge(yolo, rfdetr)
        YOLO --> NMS : deteccoes locais
    }

    component "ngrok\n(URL publica de desenvolvimento)" as TUNNEL
    TUNNEL --> API : HTTPS → HTTP interno
}

' ── Servicos de Notificacao (externos, acionados pelo backend) ───────────────

node "E-mail\n(Servico Externo)" as NOTIF {
    component "Gmail SMTP\nsmtp.gmail.com:587\n(alertas de ticket)" as GMAIL
}

' ── Roboflow (API externa) ───────────────────────────────────────────────────

node "Roboflow\n(API Cloud)" as ROBOFLOW {
    component "RF-DETR Workflow\n(smart-bottle-counting)" as RFDETR
}

' ── Firebase (Google Cloud) ──────────────────────────────────────────────────

node "Firebase\n(Google Cloud)" as FIREBASE {
    database "Cloud Firestore\n/usuarios /inventario\n/chamados /notificacoes\n/convites_suporte" as FS
    database "Cloud Storage\nscans/{uid}/*.jpg" as STORAGE
    component "Firebase Auth\n(JWT — email/password)" as AUTH
}

' ── Conexoes ─────────────────────────────────────────────────────────────────

APP --> TUNNEL : HTTPS POST /v1/detect\n(Base64 + Bearer JWT)
API --> RFDETR : inference-sdk\n(paralelo com YOLO)
RFDETR --> NMS : deteccoes nuvem
NMS --> API : resultado final
API --> APP : JSON {detections[], meta}

APP --> AUTH : login / getIdToken
AUTH --> API : verify_id_token() [Admin SDK]

API --> GMAIL : smtplib STARTTLS\n(alerta de ticket)

APP --> FS : onSnapshot / addDoc\n(tempo real)
APP --> STORAGE : uploadString(base64)\ngetDownloadURL()

' ── Nota ─────────────────────────────────────────────────────────────────────

note bottom of DOCKER
  Docker resolve o problema do _lzma
  no Python/pyenv do macOS.
  Imagem: python:3.11-slim (lzma nativo).
  Volumes: yolo11m.pt + firebase-service-account.json
end note

note bottom of TUNNEL
  Expoe o backend local
  para o app mobile via
  URL publica temporaria.
end note

@enduml
