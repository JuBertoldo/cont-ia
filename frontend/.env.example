# ─────────────────────────────────────────────────────────────────────────────
# Cont.IA — Variáveis de ambiente do Frontend (React Native puro)
# Copie para .env e preencha com os valores reais do seu projeto.
# NUNCA commite o .env — ele já está no .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Sign-In (Firebase Console → Authentication → Sign-in method → Google → Web Client ID)
GOOGLE_WEB_CLIENT_ID=XXXXXXX.apps.googleusercontent.com

# ── Firebase (Firebase Console → Configurações → Seus apps → SDK config)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
FIREBASE_PROJECT_ID=seu-projeto
FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:android:abc123

# ── Backend YOLO
# Produção — Cloudflare Tunnel (URL permanente, sem abrir porta no roteador):
# YOLO_API_URL=https://api.<SEU_DOMINIO>

# Desenvolvimento local — Android Emulator (AVD):
# YOLO_API_URL=http://10.0.2.2:8000

# Desenvolvimento local — iOS Simulator:
# YOLO_API_URL=http://localhost:8000

# Desenvolvimento local — dispositivo físico na mesma rede Wi-Fi:
# YOLO_API_URL=http://192.168.x.x:8000

# Desenvolvimento local — ngrok/cloudflared quick tunnel (URL temporária):
YOLO_API_URL=https://<tunnel-url>

# Sentry — deixe vazio para desativar o monitoramento
SENTRY_DSN=
NODE_ENV=development
